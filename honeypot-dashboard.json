      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ffhc3b2546sxsd"
          },
          "format": "time_series",
          "rawSql": "\nSELECT\n  to_timestamp(floor(ts/GREATEST($__interval_ms::bigint, 10000)::float)*GREATEST($__interval_ms::bigint, 10000)/1000.0) AS time,\n  SUM(CASE WHEN event_type='cowrie.session.connect'      THEN 1 ELSE 0 END) AS \"SSH/Telnet\",\n  SUM(CASE WHEN event_type='cowrie.login.success'        THEN 1 ELSE 0 END) AS \"Logins Réussis\",\n  SUM(CASE WHEN event_type='cowrie.command.input'        THEN 1 ELSE 0 END) AS \"Commandes\",\n  SUM(CASE WHEN event_type='cowrie.session.file_upload'  THEN 1 ELSE 0 END) AS \"Upload Malware\",\n  SUM(CASE WHEN event_type='2000'                         THEN 1 ELSE 0 END) AS \"FTP\",\n  SUM(CASE WHEN event_type='3000' OR event_type='3001'    THEN 1 ELSE 0 END) AS \"HTTP\",\n  SUM(CASE WHEN event_type='8001'                         THEN 1 ELSE 0 END) AS \"MySQL\",\n  SUM(CASE WHEN event_type='14001'                        THEN 1 ELSE 0 END) AS \"RDP\",\n  SUM(CASE WHEN event_type='12001'                        THEN 1 ELSE 0 END) AS \"VNC\"\nFROM events WHERE ts BETWEEN $__from AND $__to AND (NULLIF('$port','0') IS NULL OR dst_port = NULLIF('$port','0')::integer)\nGROUP BY floor(ts/GREATEST($__interval_ms::bigint, 10000)::float) ORDER BY 1 ASC\n",
          "refId": "A"
        }
      ],
      "title": "📈 Activité dans le Temps — Toutes Sources",
      "type": "timeseries"
    },
