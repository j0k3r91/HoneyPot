          "rawSql": "SELECT CASE dst_port\n  WHEN 22   THEN '🔑 SSH (22)'\n  WHEN 23   THEN '📟 Telnet (23)'\n  WHEN 21   THEN '📁 FTP (21)'\n  WHEN 80   THEN '🌐 HTTP (80)'\n  WHEN 3306 THEN '🗄️ MySQL (3306)'\n  WHEN 3389 THEN '🖥️ RDP (3389)'\n  WHEN 5900 THEN '🖱️ VNC (5900)'\n  ELSE 'Autre (' || dst_port::text || ')' END AS port_service, COUNT(*) AS connexions FROM events WHERE dst_port > 0 AND ts BETWEEN $__from AND $__to AND (NULLIF('$port','0') IS NULL OR dst_port = NULLIF('$port','0')::integer) GROUP BY dst_port ORDER BY connexions DESC",
          "refId": "A"
